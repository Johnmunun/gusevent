# Neon PostgreSQL — Console Neon → Connection string (pooled)
# Éviter channel_binding=require sous Windows (connexion Prisma souvent impossible)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon Auth — Console Neon → Auth → Configuration → Auth URL
# Même préfixe d'endpoint que DATABASE_URL, avec neonauth + /neondb/auth
NEON_AUTH_BASE_URL="https://ep-xxx.neonauth.c-7.us-east-1.aws.neon.tech/neondb/auth"

# Secret cookies session (min. 32 caractères) — openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="your-secret-at-least-32-characters-long"

# URL publique de l'app (Vercel) — requis pour Neon Auth en production
NEXT_PUBLIC_APP_URL="https://votre-projet.vercel.app"

# Profil admin Prisma (rôles panneau) — le compte Neon Auth doit utiliser le même email
SEED_ADMIN_EMAIL="admin@gusevent.com"
SEED_ADMIN_NAME="Administrateur"
